# ──────────────────────────────────────────────────────────────────────────────
# SELVA Agency — Meta Ads Dashboard
# Railway environment variables
# Copy to .env for local dev (never commit .env with real values)
# ──────────────────────────────────────────────────────────────────────────────

# Database (TiDB / PlanetScale / MySQL-compatible)
DATABASE_URL=mysql://user:password@host:4000/dbname?ssl={"rejectUnauthorized":true}

# JWT session secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Anthropic API (AI suggestions, reports, dashboard builder)
ANTHROPIC_API_KEY=

# App public URL (used in email links)
APP_URL=https://app.selvadash.com.br

# Admin login credentials
# Email for the admin user
ADMIN_EMAIL=admin@selva.agency
# Scrypt hash of the admin password — generate with:
#   node -e "const {scryptSync,randomBytes}=require('crypto'); const s=randomBytes(16).toString('hex'); console.log(s+':'+scryptSync('YOUR_PASSWORD',s,64).toString('hex'))"
ADMIN_PASSWORD_HASH=

# SMTP for daily report emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google Calendar (per-user integration — Home agenda)
# OAuth client (Web application) from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match EXACTLY an Authorized redirect URI in the OAuth client:
GOOGLE_REDIRECT_URI=https://spaces.selva.agency/api/integrations/google/callback
# Key used to encrypt integration tokens at rest — generate with: openssl rand -hex 32
# (shared by Google Calendar and Trello)
INTEGRATIONS_ENCRYPTION_KEY=

# Trello (per-user integration — Home "Meus cards")
# API key from https://trello.com/power-ups/admin (your Power-Up) — NOT a user token
TRELLO_API_KEY=

# Storage S3-compatible (avatars + SelvaTV). Any provider: AWS S3, Cloudflare R2, MinIO…
# If unset, the app still runs and uploads show "storage não configurado".
STORAGE_PROVIDER=s3
S3_ENDPOINT=              # e.g. https://<accountid>.r2.cloudflarestorage.com (blank for AWS S3)
S3_REGION=auto            # e.g. us-east-1 (AWS) or "auto" (R2)
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL if the bucket/CDN is public-read (recommended for these public images).
# If blank, signed URLs are generated at read time (works with private buckets).
S3_PUBLIC_BASE_URL=       # e.g. https://cdn.selva.agency  or  https://pub-xxxx.r2.dev
S3_FORCE_PATH_STYLE=false # true for MinIO / some S3-compatibles

# Google Ads / GA4 (optional — only needed if using Google Ads integration)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_OAUTH_REDIRECT_URI=${APP_URL}/api/google/callback

# GitHub PAT (optional — used in daily progress report to fetch commits)
GITHUB_PAT=

# Node env
NODE_ENV=production
